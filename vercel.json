{
  "framework": "vite",
  "installCommand": "npm install --unsafe-perm",
  "buildCommand": "chmod +x node_modules/.bin/vite && node node_modules/vite/bin/vite.js build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!sitemap.xml|robots.txt|sr-logo.png|gallery/.*|assets/.*).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/gallery/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
